#!/usr/bin/env -S uv run --quiet python
"""Validate a golden chapter's YAML against the loader's structural rules
AND against the corpus database (chunk_id existence, span/quote alignment).

Usage:
    scripts/validate-golden              # defaults to ch01
    scripts/validate-golden ch01
    scripts/validate-golden ch01 --db data/corpus.sqlite

Exit code: 0 if everything checks; 1 if any check fails.

Structural checks (via tests/golden/loader.py):
  - YAML well-formed; each file top-level is a list
  - Required fields per entity kind
  - Citation FK integrity (every citations: [cit:X] reference exists)
  - Date inference_kind allowlist
  - Relative-anchor cycles + dangling anchors

Corpus checks (added by this script):
  - Every citation.chunk_id exists in corpus.sqlite
  - chunk.text[span[0]:span[1]] equals citation.quote (NFC-normalized)
  - paragraph value falls within the chunk's paragraph range
"""

from __future__ import annotations

import argparse
import sqlite3
import sys
import unicodedata
from pathlib import Path

# Allow running from repo root without PYTHONPATH gymnastics.
ROOT = Path(__file__).resolve().parent.parent
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from tests.golden.loader import GoldenLoadError, load_golden  # noqa: E402

DEFAULT_DB = Path("data/corpus.sqlite")


def _nfc(s: str) -> str:
    return unicodedata.normalize("NFC", s)


def _check_corpus(golden: dict, db_path: Path) -> list[str]:
    """Return a list of corpus-check errors (empty list means all checks passed)."""
    errors: list[str] = []
    if not db_path.exists():
        return [f"corpus db not found: {db_path}"]

    conn = sqlite3.connect(db_path)
    chunk_index: dict[str, tuple[str, int, int]] = {}
    for row in conn.execute("SELECT id, text, paragraph_start, paragraph_end FROM chunks"):
        chunk_index[row[0]] = (row[1], row[2], row[3])

    for c in golden.get("citations", []):
        cid = c.get("id", "<no-id>")
        chunk_id = c.get("chunk_id")
        if chunk_id not in chunk_index:
            errors.append(f"{cid}: chunk_id '{chunk_id}' not in corpus.sqlite")
            continue
        text, ps, pe = chunk_index[chunk_id]

        # span / quote alignment
        span = c.get("span")
        quote = c.get("quote", "")
        if not isinstance(span, list) or len(span) != 2:
            errors.append(f"{cid}: span must be [start, end]")
            continue
        start, end = span
        if not (0 <= start <= end <= len(text)):
            errors.append(
                f"{cid}: span {span} out of range for chunk '{chunk_id}' "
                f"(text length {len(text)})"
            )
            continue
        actual = _nfc(text[start:end])
        expected = _nfc(quote)
        if actual != expected:
            # Try to find the quote elsewhere in the chunk to suggest a fix
            normalized_text = _nfc(text)
            hint = ""
            if expected and expected in normalized_text:
                idx = normalized_text.index(expected)
                hint = f" (quote occurs at offsets [{idx}, {idx + len(expected)}])"
            errors.append(
                f"{cid}: chunk.text[{start}:{end}] = {actual!r} ≠ quote = {expected!r}{hint}"
            )

        # paragraph check (paragraph is 1-based in golden by convention; chunk's range is 0-based half-open)
        paragraph = c.get("paragraph")
        if isinstance(paragraph, int):
            if not (ps <= paragraph <= pe):
                errors.append(
                    f"{cid}: paragraph {paragraph} outside chunk's range [{ps}, {pe}]"
                )

    return errors


def main() -> int:
    parser = argparse.ArgumentParser(description="Validate a golden chapter YAML set.")
    parser.add_argument("chapter_dir", nargs="?", default="ch01",
                        help="subdir under tests/golden/ (default: ch01)")
    parser.add_argument("--db", type=Path, default=DEFAULT_DB,
                        help=f"corpus sqlite (default: {DEFAULT_DB})")
    parser.add_argument("--skip-corpus", action="store_true",
                        help="run structural checks only; don't open corpus.sqlite")
    args = parser.parse_args()

    chapter_path = Path("tests/golden") / args.chapter_dir
    if not chapter_path.is_dir():
        print(f"✗ chapter dir not found: {chapter_path}", file=sys.stderr)
        return 1

    # Structural checks
    try:
        golden = load_golden(chapter_path)
    except GoldenLoadError as e:
        print(f"✗ structural: {e}", file=sys.stderr)
        return 1
    counts = {k: len(v) for k, v in golden.items()}
    print(f"✓ structural: {counts}")

    if args.skip_corpus:
        return 0

    # Corpus checks
    errors = _check_corpus(golden, args.db)
    if errors:
        print(f"✗ corpus: {len(errors)} error(s)", file=sys.stderr)
        for e in errors:
            print(f"  - {e}", file=sys.stderr)
        return 1
    print(f"✓ corpus: all {counts['citations']} citation(s) align with corpus.sqlite")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
